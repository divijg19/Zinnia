{
	"$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!**/coverage",
			"!**/node_modules",
			"!**/*.min.js",
			"!**/dist",
			"!assets/cards",
			"!**/stats/coverage",
			"!streak/tests/expected",
			"!tests/api/tmp",
			"!**/leetcode/packages/**/dist",
			"!**/streak/src/demo",
			"!**/leetcode/packages/**/src/demo",
			"!**/leetcode/packages/**/src/**/demo",
			"!**/.vercel",
			"!bun.lock",
			"!package.json",
			"!api/_build",
			"!trophy/dist",
			"!streak/dist",
			"!stats/api",
			"!./tmp",
			"!tmp",
			"!.git/",
			"!node_modules/",
			"!dist/",
			"!*.map"
		],
		"maxSize": 1048576
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
